# =============================================================================
# GradAdmissions Platform — Environment Configuration
# Copy this file to .env and fill in all required values.
# Never commit .env to version control.
# =============================================================================

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://graduser:gradpass@localhost:5432/graddb
# For test environment (used by Vitest integration tests)
DATABASE_URL_TEST=postgresql://graduser:gradpass@localhost:5432/graddb_test

# ── Session ───────────────────────────────────────────────────────────────────
# Idle timeout in minutes (default: 30)
SESSION_IDLE_TIMEOUT_MINUTES=30
# Absolute timeout in hours (default: 12)
SESSION_ABSOLUTE_TIMEOUT_HOURS=12

# ── Attachments ───────────────────────────────────────────────────────────────
# Root directory for stored review attachments (relative to repo root or absolute)
ATTACHMENT_STORAGE_ROOT=./storage/attachments
# Max file size in bytes (default: 10 MB = 10485760)
ATTACHMENT_MAX_FILE_BYTES=10485760
# Max number of attachments per review submission
ATTACHMENT_MAX_FILES_PER_REVIEW=5

# ── Encryption ────────────────────────────────────────────────────────────────
# AES-256-GCM key: exactly 64 hex characters (32 bytes).
# Generate a new key:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Docker usage: set this in your .env file (never commit it).
LOCAL_ENCRYPTION_KEY=CHANGE_ME_32_BYTE_HEX_STRING_HERE_64_CHARS_EXACTLY

# ── Search ────────────────────────────────────────────────────────────────────
SEARCH_DEFAULT_LANGUAGE=english

# ── Personalization ───────────────────────────────────────────────────────────
# Browsing history retention in days (default: 180)
HISTORY_RETENTION_DAYS=180

# ── Review Aggregation Policies ───────────────────────────────────────────────
# Enable extreme-value trimming
REVIEW_TRIM_ENABLED=true
# Percentage to trim from top and bottom (e.g., 10 = drop top 10% and bottom 10%)
REVIEW_TRIM_PERCENT=10
# Minimum number of scores before trimming is applied
REVIEW_TRIM_MIN_COUNT=7
# Standard deviation threshold to trigger second-pass escalation
REVIEW_VARIANCE_THRESHOLD=1.8

# ── Logging ───────────────────────────────────────────────────────────────────
# Log level: trace | debug | info | warn | error | fatal
LOG_LEVEL=info
