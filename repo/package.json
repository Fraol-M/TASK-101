{
  "name": "grad-admissions-platform",
  "version": "1.0.0",
  "description": "GradAdmissions Operations & Review Platform — offline-first backend",
  "type": "module",
  "engines": {
    "node": ">=20.0.0"
  },
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "node --watch src/server.js",
    "migrate": "knex migrate:latest --knexfile knexfile.js",
    "migrate:rollback": "knex migrate:rollback --knexfile knexfile.js",
    "migrate:status": "knex migrate:status --knexfile knexfile.js",
    "seed": "knex seed:run --knexfile knexfile.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run tests/unit",
    "test:api": "vitest run tests/api",
    "test:integration": "vitest run tests/integration",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint src tests",
    "reindex-search": "node scripts/reindex-search.js",
    "purge-history": "node scripts/purge-expired-data.js",
    "export-metrics": "node scripts/export-metrics.js",
    "rotate-demo-passwords": "node scripts/rotate-demo-passwords.js",
    "self-audit": "node scripts/self-audit-precheck.js",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up",
    "docker:up:dev": "docker compose --profile dev up",
    "docker:down": "docker compose down",
    "docker:down:volumes": "docker compose down -v",
    "docker:test": "docker compose --profile test run --rm test",
    "docker:test:unit": "docker compose --profile test run --rm test npm run test:unit",
    "docker:test:integration": "docker compose --profile test run --rm test npm run test:integration",
    "docker:migrate": "docker compose run --rm migrate",
    "docker:logs": "docker compose logs -f app",
    "docker:shell": "docker compose exec app sh"
  },
  "dependencies": {
    "@koa/router": "^13.1.0",
    "bcrypt": "^5.1.1",
    "koa": "^2.15.3",
    "koa-body": "^6.0.1",
    "knex": "^3.1.0",
    "pg": "^8.13.1",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "prom-client": "^15.1.3",
    "ulid": "^2.3.0",
    "uuid": "^11.0.3",
    "zod": "^3.23.8",
    "file-type": "^19.6.0"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^2.1.8",
    "autocannon": "^7.15.0",
    "eslint": "^9.15.0",
    "supertest": "^7.0.0",
    "vitest": "^2.1.8"
  }
}
