# =============================================================================
# .dockerignore — Keep the build context lean.
# Files listed here are NOT sent to the Docker daemon.
# =============================================================================

# Dependencies (installed inside the image)
node_modules

# Environment files (never bake secrets into images)
.env
.env.*
!.env.example

# Storage (mounted as Docker volumes at runtime)
storage/

# Logs
logs/
*.log

# Editor / OS artefacts
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
*.swo

# Git
.git
.gitignore
.gitattributes

# Test output / coverage
coverage/
.nyc_output/

# CI
.github/

# Docker files themselves (already in the build context, exclude the others)
docker-compose.override.yml

# Docs
*.md
!README.md
